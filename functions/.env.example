# Cloud Functions runtime configuration.
#
# The Admin SDK auto-discovers credentials when deployed via
# the Firebase CLI (service account is injected automatically).
# Locally, set GOOGLE_APPLICATION_CREDENTIALS to the path of
# your service-account JSON:
#
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/hudson-65e88-firebase-adminsdk-*.json
#
# Never commit the service-account JSON to the repo.
GOOGLE_APPLICATION_CREDENTIALS=