rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── HLS AES key files ───
    // Authenticated users only. The key is the actual secret.
    match /keys/{file} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── HLS segments + playlists ───
    // Public read — segments are AES-128 encrypted, useless without the key.
    // The key is still auth-gated below. This lets the client fetch .ts files
    // directly from Storage (no Cloud Function proxy), saving ~100% of CF egress.
    match /tracks-hls/{path=**} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Legacy plain .mp3 in /tracks/ ───
    // Hard-closed.
    match /tracks/{file} {
      allow read, write: if false;
    }

    // ─── Default deny ───
    match /{path=**} {
      allow read, write: if false;
    }
  }
}